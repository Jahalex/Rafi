# ════════════════════════════════════════
# RAFI — Environment Variables (EXAMPLE)
# ════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Solana ──────────────────────────────
NEXT_PUBLIC_SOLANA_NETWORK=devnet
# Triton / Helius RPC (never use public RPC in production)
NEXT_PUBLIC_SOLANA_RPC_URL=https://your-rpc.rpcpool.com/YOUR_KEY

# ── Privy Auth ──────────────────────────
# Get from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
NEXT_SECRET_PRIVY=your_privy_app_secret

# ── Supabase ────────────────────────────
# Get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# ⚠️ NO NEXT_PUBLIC_ prefix — service role key MUST stay server-side only (API routes)
# Never expose this in client code — it bypasses ALL Supabase Row Level Security
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Rafi Program ────────────────────────
NEXT_PUBLIC_RAFI_PROGRAM_ID=5eMM9jZraq6M9RtKJQqdmgQAAy1bJHohBQRGyiWeQ2kg

# ── Pyth Hermes (price oracle) ──────────
# Free public endpoint (rate-limited). For production, use Triton Pythnet:
# NEXT_PUBLIC_HERMES_URL=https://your-rpc.mainnet.pythnet.rpcpool.com/hermes
NEXT_PUBLIC_HERMES_URL=https://hermes.pyth.network

# ── Helius Webhook (indexer security) ───
# Generate a random secret: openssl rand -hex 32
# Set the same value in Helius Dashboard → Webhook → Secret
HELIUS_WEBHOOK_SECRET=your_random_hex_secret
